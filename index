<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>KB Home Design Studio Check-In</title>

<style>
*{
    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Arial, Helvetica, sans-serif;
}

body{
    background:#f4f4f4;
    display:flex;
    justify-content:center;
    align-items:center;
    min-height:100vh;
}

.container{
    width:95%;
    max-width:900px;
    background:white;
    border-radius:18px;
    box-shadow:0 8px 30px rgba(0,0,0,.15);
    overflow:hidden;
}

.header{
    background:#FDB913;
    padding:35px;
    text-align:center;
}

.logo{
    max-width:260px;
    margin-bottom:20px;
}

.header h1{
    color:#222;
    font-size:2rem;
}

.content{
    padding:35px;
    text-align:center;
}

.content p{
    font-size:1.15rem;
    color:#555;
    margin-bottom:30px;
    line-height:1.5;
}

iframe{
    width:100%;
    height:850px;
    border:none;
    border-radius:12px;
}
</style>
</head>

<body>

<div class="container">

    <div class="header">

        <!-- Replace this with your KB Home logo -->
        <img src="images/kbhome-logo.png" class="logo" alt="KB Home">

        <h1>Welcome to the KB Home Design Studio</h1>

    </div>

    <div class="content">

        <p>
            We're excited you're here!<br><br>
            Please complete the check-in form below to let our Design Studio team know you've arrived.
        </p>

        <!-- Replace with your Microsoft Forms embed code -->
<iframe width="640px" height="480px" src="https://forms.office.com/Pages/ResponsePage.aspx?id=WuvpfmAbI0SpS2Rui8bU20Z6wvfRWLpCvu4HtfZi5gNUQkMzMjRTR0hHT1o2MEg1OEZXMVM2VFE1Qi4u&embed=true" frameborder="0" marginwidth="0" marginheight="0" style="border: none; max-width:100%; max-height:100vh" allowfullscreen webkitallowfullscreen mozallowfullscreen msallowfullscreen> </iframe>
    </div>

</div>

</body>
</html>
